{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/adr-session-start.sh",
            "statusMessage": "Checking ADR status..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/adr-bash-watch.sh",
            "statusMessage": "Checking ADR for new branch..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/adr-stop-check.sh",
            "statusMessage": "Checking ADR completeness..."
          }
        ]
      }
    ]
  }
}
